# --- LLM provider (OpenRouter; API OpenAI-compatible) ---
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Catálogo: https://openrouter.ai/models
DEFAULT_MODEL=deepseek/deepseek-v4-flash
# Opcional — aparecem nos rankings do OpenRouter:
# OPENROUTER_SITE_URL=http://localhost:5173
# OPENROUTER_APP_NAME=Azion Chat

# --- Server URLs / ports ---
MCP_SERVER_URL=http://localhost:3002/mcp
SERVER_PORT=3001
MCP_PORT=3002

# --- Web (Vite) ---
VITE_SERVER_URL=http://localhost:3001
